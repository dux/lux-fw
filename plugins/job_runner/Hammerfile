namespace :job_runner do
  task :start do
    desc 'Start job runner'
    needs :app

    proc do |_opts|
      jobs_file = './lib/jobs.rb'
      require jobs_file if File.exist?(jobs_file)

      LuxJob.init!
      LuxJob.run
    end
  end

  task :restart do
    desc 'Restart job server'

    proc do |_opts|
      # job-runner-soho_tasks
    end
  end
end
