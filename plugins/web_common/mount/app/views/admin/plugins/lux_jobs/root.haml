- # Job runner dashboard. URL: /admin/plugins/lux_jobs
- # Reads LuxJob::JOBS + the lux_jobs table directly; no API roundtrip.
- # Styles ship inline (lj-* classes) so the page renders correctly in any
- # host app regardless of its asset bundle / utility purging.

- registered = LuxJob::JOBS.map do |name, opts|
  - db_job = LuxJob.first(name: name.to_s)
  - { name: name, every: opts[:every], timeout: opts[:timeout] || LuxJob::DEFAULT_TIMEOUT, db: db_job }
- recent = LuxJob.tail_log(lines: 100)
- last_id = LuxJob.last_log_id

:css
  .lj-table { border-collapse: collapse; width: 100%; font-size: 14px; }
  .lj-table th { text-align: left; padding: 8px 12px; border-bottom: 2px solid #e5e7eb; color: #6b7280; font-weight: 600; white-space: nowrap; }
  .lj-table td { padding: 10px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
  .lj-table tr:hover td { background: #fafafa; }
  .lj-table a { color: #2563eb; text-decoration: none; }
  .lj-table a:hover { text-decoration: underline; }
  .lj-card { border: 1px solid #e5e7eb; border-radius: 10px; background: #fff; overflow: hidden; }
  .lj-card .lj-table th:first-child, .lj-card .lj-table td:first-child { padding-left: 16px; }
  .lj-card .lj-table th:last-child, .lj-card .lj-table td:last-child { padding-right: 16px; }
  .lj-card .lj-table tr:last-child td { border-bottom: none; }
  .lj-st { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; background: #e5e7eb; color: #374151; }
  .lj-st-ok   { background: #d1fae5; color: #047857; }
  .lj-st-run  { background: #dbeafe; color: #1d4ed8; }
  .lj-st-wait { background: #fef3c7; color: #92400e; }
  .lj-st-err  { background: #fee2e2; color: #b91c1c; }
  .lj-log { margin-top: 12px; max-height: 460px; overflow-y: auto; padding: 12px 14px; border-radius: 8px; background: #0f172a; color: #cbd5e1; font: 13px/1.6 ui-monospace, SFMono-Regular, Menlo, monospace; }
  .lj-log .lj-line { white-space: pre-wrap; word-break: break-word; padding: 1px 0; }
  .lj-log .lj-line.error { color: #fca5a5; }
  .lj-log .lj-line .lj-time { color: #64748b; margin-right: 10px; }

%h1 LuxJob Dashboard

%h2 Registered Jobs
.lj-card
  %table.lj-table
    %tr
      %th Name
      %th Schedule
      %th Timeout
      %th Last Run
      %th Next Run
      %th Status
      %th Response
    - registered.each do |row|
      %tr
        %td
          %a{ href: "/admin/plugins/lux_jobs/show?name=#{row[:name]}" }= row[:name]
        %td
          - if row[:every]
            = "every #{row[:every].parts.map { |u, v| "#{v} #{u}" }.join(', ')}"
          - else
            on demand
        %td #{row[:timeout]}s
        %td
          - if row[:db]&.updated_at
            #{row[:db].updated_at.strftime('%Y-%m-%d %H:%M:%S')} (#{LuxJob.time_relative(row[:db].updated_at)})
          - else
            \-
        %td
          - if row[:db]&.run_at
            #{row[:db].run_at.strftime('%Y-%m-%d %H:%M:%S')} (#{LuxJob.time_relative(row[:db].run_at)})
          - else
            \-
        %td
          - if row[:db]&.status
            %span{ class: LuxJob.status_css(row[:db].status) }= row[:db].status
          - else
            \-
        %td= row[:db]&.response.to_s[0, 50].presence || '-'

%h2 Recent Log (last 100 entries)
.lj-log#log-box{ data: { last_id: last_id, job: '' } }
  - if recent.empty?
    .lj-line No log entries yet
  - else
    - recent.each do |line|
      - parsed = LuxJob.parse_log_line(line)
      .lj-line{ class: ('error' if line.include?('ERROR')) }
        %span.lj-time= LuxJob.time_ago(parsed[:time])
        = parsed[:message]

:javascript
  // pjax runs response scripts before morphing the new DOM in; defer to the next
  // frame so log-box exists and the live-tail keeps polling after a pjax navigation
  requestAnimationFrame(function() {
    var box = document.getElementById('log-box');
    if (!box) return;
    var lastId = box.dataset.lastId || '';
    var job    = box.dataset.job || '';

    setInterval(async function() {
      try {
        var body = { name: job || null };
        var resp = await fetch('/api/lux_jobs/poll', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(body)
        });
        var data = await resp.json();
        var newId = data && data.data && data.data.last_id;
        if (newId && newId !== lastId) {
          var pageResp = await fetch(window.location.href, { credentials: 'same-origin' });
          var html = await pageResp.text();
          var doc  = new DOMParser().parseFromString(html, 'text/html');
          var src  = doc.querySelector('.container') || doc.body;
          var dst  = document.querySelector('.container') || document.body;
          if (window.Idiomorph) { window.Idiomorph.morph(dst, src); }
          lastId = newId;
        }
      } catch (e) { console.error('poll error:', e); }
    }, 3000);
  });
