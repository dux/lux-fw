:ruby
  @list = Dir.entries('./log').select{ |it| it.include?('.log') }.sort

  def self.filesize(size)
    units = ['B', 'KiB', 'MiB', 'GiB', 'TiB', 'Pib', 'EiB']

    return '0.0 B' if size == 0
    exp = (Math.log(size) / Math.log(1024)).to_i
    exp = 6 if exp > 6

    '%.1f %s' % [size.to_f / 1024 ** exp, units[exp]]
  end

%h2 Click to see the log

.mt-3.mb-3
  %ui-search

.boxb
  %table.table.hover
    %tr
      %th Log name
      %th.r{ style: 'width: 200px;' } Size
      %th.r{ style: 'width: 200px;' } Last update
    - for el in @list
      - next if params[:q] && !el.include?(params[:q])
      %tr{ href: "/admin/plugins/sys_logs/show?name=#{el}" }
        %td= el
        %td.r= filesize File.size('./log/%s' % el)
        %td.r= Time.agop Time.now - File.mtime('./log/%s' % el)
