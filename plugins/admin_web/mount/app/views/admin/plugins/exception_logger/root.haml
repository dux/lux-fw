:ruby
  # Exception list. URL: /admin/plugins/exception_logger
  # Rendered by the host's AdminController via auto_find_template; data is
  # looked up inline (no plugin controller for GET).

  @prefix       = '/admin/plugins/exception_logger'
  @klass_filter = lux.params[:klass]
  @user_filter  = lux.params[:user]
  @status       = lux.params[:status] || 'open'
  @days         = lux.params[:days]   || '7'
  @since        = @days == 'all' ? nil : @days.to_i.days.ago

  @list  = LuxException.get_list klass: @klass_filter, email: @user_filter, since: @since, status: @status
  @total = LuxException.size  klass: @klass_filter, since: @since, status: @status

:javascript
  window.exceptionPickUser  = () => Dialog.load('#{@prefix}/select_user_dialog',        (email) => Pjax.qs('user',  email));
  window.exceptionPickClass = () => Dialog.load('#{@prefix}/select_error_class_dialog', (klass) => Pjax.qs('klass', klass));

.flex.items-center.justify-between.mb-4
  %h1.h1 Exceptions
  .text-sm.text-slate-500.bg-white.rounded.shadow-sm.px-3.py-1 total: #{@total}

.flex.flex-wrap.items-center.gap-2.mb-3
  %span.text-sm.text-slate-500.w-15 Range:
  %filter-btn{ filter: 'days', value: '1' } 1d
  %filter-btn{ filter: 'days', value: '7', default: true } 7d
  %filter-btn{ filter: 'days', value: '30' } 30d
  %filter-btn{ filter: 'days', value: '365' } 1y
  %filter-btn{ filter: 'days', value: 'all' } all

.flex.flex-wrap.items-center.gap-2.mb-3
  %span.text-sm.text-slate-500.w-15 Status:
  %filter-btn{ filter: 'status', value: 'open', default: true } Open
  %filter-btn{ filter: 'status', value: 'all' } All
  %filter-btn{ filter: 'status', value: 'resolved' } Resolved

.flex.flex-wrap.items-center.gap-2.mb-4
  %span.text-sm.text-slate-500.w-15 Filter by:
  %filter-btn{ filter: 'klass', value: @klass_filter, onclick: 'exceptionPickClass()' } Error Class
  %filter-btn{ filter: 'user',  value: @user_filter,  onclick: 'exceptionPickUser()'  } User

= table @list, not_found: 'no exceptions' do |t|
  - t.href { |o| '%s/show?uid=%s' % [@prefix, CGI.escape(o.uid.to_s)] }
  - t.col(title: 'Class', width: 250) { |o| { class: 'badge', href: '%s/?klass=%s' % [@prefix, CGI.escape(o.klass.to_s)], onclick: 'event.stopPropagation()' }.tag(:a, CGI.escapeHTML(o.klass.to_s)) }
  - t.col(title: 'Message')              { |o| CGI.escapeHTML(LuxException.trim(o.message, 200)) }
  - t.col(title: 'Times', width: 60, align: :c) { |o| o.times }
  - t.col(title: 'Last & first', width: 180)    { |o| [LuxException.time_ago(o.last_at), LuxException.time_ago(o.first_at)].join('<br>') }
  - t.col(title: 'Resolved', width: 80, align: :c) { |o| { class: o.is_resolved ? 'badge badge-success' : 'badge' }.tag(:span, o.is_resolved ? 'yes' : 'no') }
