# Lux deploy env template. Rendered by the deploy plugin before being
# uploaded to the server. Placeholders are replaced from:
#   - git: GIT_BRANCH, GIT_BRANCH_UNDERSCORE
#   - plugin: PORT, DIR, RUBY, RUBY_DIR
#   - .yaml: every key uppercased (SERVER, DOMAIN, ...)

OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
RACK_ENV=production
LUX_LIVE=true

# 64 hex chars; generate with: openssl rand -hex 32
SECRET=replace-me

# Unix-socket connection uses peer auth as the deployer PG role (set up by
# deploy:doctor). Switch to postgres://user:pass@host/db for remote DBs.
DB_URL=postgresql:///{{GIT_BRANCH_UNDERSCORE}}

# DOMAIN comes from .yaml. Override here only when you need a
# branch-specific value (see .env.staging).
DOMAIN={{DOMAIN}}
