[Unit]
Description=Lux web - <%= app %>
After=network.target

[Service]
Type=simple
User=<%= user %>
WorkingDirectory=<%= working_dir %>
EnvironmentFile=-<%= working_dir %>/.env
ExecStart=<%= bundle %> exec lux server -e production -p <%= port %>
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
