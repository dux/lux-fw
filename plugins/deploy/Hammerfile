require_relative 'lib/lux_deploy'

module LuxDeployHammer
  module_function

  def profile(opts)
    opts[:profile] || opts[:args].first || 'default'
  end

  def run(opts)
    yield
  rescue => e
    LuxDeploy.handle_cli_error(e, quiet: opts[:quiet])
  end
end

task :deploy do
  desc 'Deploy app to PROFILE (atomic, with health check)'
  opt :profile, desc: 'Deploy profile (positional ok)'
  opt :app, desc: 'App identifier'
  opt :host, desc: 'SSH target USER@HOST'
  opt :config, desc: 'Path to config/deploy.json'
  opt :path, desc: 'Remote app path'
  opt :src, desc: 'Local rsync source'
  opt :domain, desc: 'Caddy domain or comma-separated domains'
  opt :db_name, desc: 'Postgres database name'
  opt :db_user, desc: 'Postgres role name'
  opt :basic_auth, desc: 'HTTP basic auth user:pass'
  opt :port, desc: 'App port'
  opt :repo, desc: 'Git repo URL for --branch deploys'
  opt :branch, desc: 'Git branch/ref to clone remotely'
  opt :ruby, desc: 'Ruby version'
  opt :env, desc: 'Env override KEY=VAL or KEY (comma-separated ok)'
  opt :service_user, desc: 'Service user that owns code and runs systemd units (default deployer)'
  opt :dry_run, type: :boolean, default: false, desc: 'Print resolved plan, do not execute'
  opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

  proc do |opts|
    LuxDeployHammer.run(opts) { LuxDeploy::Commands.deploy(LuxDeployHammer.profile(opts), opts) }
  end
end

