    opt :keep, type: :boolean, default: false, desc: 'Keep the local stack running after health checks'
    opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

    proc do |opts|
      LuxDeployHammer.run(opts) { LuxDeploy::Commands.test(LuxDeployHammer.profile(opts), opts) }
