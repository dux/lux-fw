    desc 'Hand a Claude CLI prompt that generates Dockerfile + compose + deploy.json'
    opt :print, type: :boolean, default: false, desc: 'Print the prompt to stdout instead of invoking claude'
    opt :dry_run, type: :boolean, default: false, desc: 'Write the prompt file but do not invoke claude'

    proc do |opts|
      LuxDeployHammer.run(opts) { LuxDeploy::Commands.llm_prepare(nil, opts) }
    end
  end

  task :compose do
    desc 'Run a docker compose subcommand against the remote stack (lux deploy:compose [PROFILE] -- ps)'
    opt :profile, desc: 'Deploy profile (positional ok)'
    opt :app, desc: 'App identifier'
    opt :server, desc: 'SSH target USER@SERVER'
    opt :config, desc: 'Path to config/deploy.json'
    opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

    proc do |opts|
      opts[:args] = Array(opts[:args])
      sep = opts[:args].index('--')
      passthrough = sep ? opts[:args][(sep + 1)..] : LuxDeployHammer.passthrough(opts)
      LuxDeployHammer.run(opts) do
        LuxDeploy::Commands.compose(LuxDeployHammer.profile(opts), opts.merge(args: passthrough))
      end
    end
  end
end
