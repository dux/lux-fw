- # Exception list. URL: /admin/plugins/exception_logger
- # Rendered by the host's AdminController via auto_find_template; data is
- # looked up inline (no plugin controller for GET).

- prefix       = '/admin/plugins/exception_logger'
- klass_filter = lux.params[:klass]
- user_filter  = lux.params[:user]
- users        = LuxException.get_users
- types        = LuxException.get_error_types
- list         = LuxException.get_list klass: klass_filter, email: user_filter
- total        = LuxException.size

.flex.items-center.justify-between.mb-5
  %h1.text-2xl.font-semibold Exceptions
  .text-sm.text-slate-500.bg-white.rounded.shadow-sm.px-3.py-1
    total: #{total}

.flex.flex-wrap.gap-3.mb-4
  %details.bg-white.rounded.shadow-sm.flex-1{ open: !!user_filter }
    %summary.cursor-pointer.px-3.py-2.text-sm.font-medium
      Filter by user (last 7d)
      - if user_filter
        %span.text-slate-500.font-normal &middot; #{user_filter}
    .p-3.border-t.border-slate-100.flex.flex-wrap.gap-2
      - if users.empty?
        %span.text-slate-400.text-sm no users in last 7 days
      - users.each do |u|
        %a.text-sm.bg-slate-50.hover:bg-slate-100.border.border-slate-200.rounded.px-2.py-1{ href: '%s/?user=%s' % [prefix, CGI.escape(u[:email].to_s)] }
          &= u[:email]
          %span.text-slate-400  (#{u[:count]})

  %details.bg-white.rounded.shadow-sm.flex-1{ open: !!klass_filter }
    %summary.cursor-pointer.px-3.py-2.text-sm.font-medium
      Filter by class
      - if klass_filter
        %span.text-slate-500.font-normal &middot; #{klass_filter}
    .p-3.border-t.border-slate-100.flex.flex-wrap.gap-2
      - if types.empty?
        %span.text-slate-400.text-sm no recent types
      - types.each do |t|
        - klass = t[:klass].to_s
        - muted = LuxException::IGNORE.include?(klass)
        %a.text-sm.border.rounded.px-2.py-1{ href: '%s/?klass=%s' % [prefix, CGI.escape(klass)], class: muted ? 'text-slate-400 bg-white border-slate-200' : 'bg-slate-50 hover:bg-slate-100 border-slate-200' }
          &= klass
          %span.text-slate-400  (#{t[:count]})

- if klass_filter || user_filter
  %p.mb-3
    %a.text-sm.text-blue-600.hover:underline{ href: prefix + '/' } clear filters

.bg-white.rounded.shadow-sm.overflow-hidden
  %table.w-full.text-sm
    %thead.bg-slate-50.text-slate-600
      %tr
        %th.text-left.font-medium.px-3.py-2{ style: 'width: 250px;' } Class
        %th.text-left.font-medium.px-3.py-2 Message
        %th.text-center.font-medium.px-3.py-2{ style: 'width: 60px;' } Times
        %th.text-left.font-medium.px-3.py-2{ style: 'width: 180px;' } Last &amp; first
        %th.text-center.font-medium.px-3.py-2{ style: 'width: 80px;' } Resolved
    %tbody
      - list.each do |el|
        %tr.border-t.border-slate-100.hover:bg-slate-50{ class: ('opacity-50' if el[:is_resolved]) }
          %td.px-3.py-2.align-top
            %a.inline-block.text-xs.bg-slate-100.hover:bg-slate-200.rounded.px-2.py-1{ href: '%s/?klass=%s' % [prefix, CGI.escape(el[:klass].to_s)] }
              &= el[:klass]
          %td.px-3.py-2.align-top
            %a.text-blue-700.hover:underline{ href: '%s/show?uid=%s' % [prefix, CGI.escape(el[:uid].to_s)] }
              &= LuxException.trim(el[:message], 200)
          %td.px-3.py-2.align-top.text-center= el[:times]
          %td.px-3.py-2.align-top.text-slate-500
            = LuxException.time_ago(el[:last_at])
            %br
            = LuxException.time_ago(el[:first_at])
          %td.px-3.py-2.align-top.text-center
            - if el[:is_resolved]
              %span.text-emerald-600 yes
            - else
              %span.text-slate-400 no
      - if list.empty?
        %tr
          %td.text-center.text-slate-400.py-6{ colspan: 5 } no exceptions
