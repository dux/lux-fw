:ruby
  # Event log list. URL: /admin/plugins/event_log
  # Rendered by the host's AdminController via auto_find_template; data is
  # looked up inline (no plugin controller for GET).

  @prefix = '/admin/plugins/event_log'

  @current_path = LuxEventLogView.apply lux   # handles ?save_as / ?forget
  @saved_views  = LuxEventLogView.order(:name).all

  @tag    = lux.params[:tag]
  @days   = lux.params[:days] || '7'
  @since  = @days == 'all' ? nil : @days.to_i.days.ago
  @from   = (Date.parse(lux.params[:from]) rescue nil)
  @to     = (Date.parse(lux.params[:to])   rescue nil)

  @list = LuxEventLog.order(Sequel.desc(:created_at))

  # explicit from/to window wins over the days preset
  if @from || @to
    @list = @list.xwhere('created_at >= ?', @from)   if @from
    @list = @list.xwhere('created_at < ?',  @to + 1) if @to
  elsif @since
    @list = @list.xwhere('created_at >= ?', @since)
  end

  @list = @list.where_all(@tag, :tags) if @tag

  @top_tags = @list.all_tags limit: 15
  @total    = @list.count

  def self.trim str, len = 120
    str.length > len ? CGI.escapeHTML(str[0, len]) + '&hellip;' : CGI.escapeHTML(str)
  end

.flex.items-center.justify-between.mb-4
  %h1.h1 Event log
  .flex.items-center.gap-3
    %button.text-sm.text-blue-600.hover:underline.cursor-pointer{ type: 'button', onclick: "var n = prompt('Save this view as:'); if (n) Pjax.qs('save_as', n)" } Save view
    %a.text-sm.text-blue-600.hover:underline{ href: "#{@prefix}/funnel" } Funnel &rarr;
    .text-sm.text-slate-500.bg-white.rounded.shadow-sm.px-3.py-1 total: #{@total}

- if @saved_views.first
  .flex.flex-wrap.items-center.gap-2.mb-3
    %span.text-sm.text-slate-500.w-15 Saved:
    - for v in @saved_views
      %span.inline-flex.items-center
        %a.badge{ class: v.path == @current_path ? 'badge-success' : nil, href: v.path }= CGI.escapeHTML v.name
        %a.text-xs.text-slate-400.hover:text-red-600.ml-1.cursor-pointer{ onclick: "Pjax.qs('forget', #{v.name.to_json})" } &times;

.flex.flex-wrap.items-center.gap-2.mb-3
  %span.text-sm.text-slate-500.w-15 Range:
  %filter-btn{ filter: 'days', value: '1' } 1d
  %filter-btn{ filter: 'days', value: '7', default: true } 7d
  %filter-btn{ filter: 'days', value: '30' } 30d
  %filter-btn{ filter: 'days', value: '365' } 1y
  %filter-btn{ filter: 'days', value: 'all' } all
  %span.text-sm.text-slate-400.ml-2 or
  %input.text-sm.border.border-slate-200.rounded.bg-white.px-2.py-1{ type: 'date', value: lux.params[:from], onchange: "Pjax.qs('from', this.value)" }
  %span.text-sm.text-slate-400 &ndash;
  %input.text-sm.border.border-slate-200.rounded.bg-white.px-2.py-1{ type: 'date', value: lux.params[:to], onchange: "Pjax.qs('to', this.value)" }

- if @top_tags.first
  .flex.flex-wrap.items-center.gap-2.mb-4
    %span.text-sm.text-slate-500.w-15 Tags:
    - for tag in @top_tags
      %filter-btn{ filter: 'tag', value: tag[:name] }= '%s (%s)' % [tag[:name], tag[:cnt]]

= table @list, not_found: 'no events' do |t|
  - t.col :created_at, title: 'When', as: :ago, width: 130
  - t.col(title: 'Tags', width: 260) { |o| o.tags.map { |tag| { class: 'badge', href: '%s?tag=%s' % [@prefix, CGI.escape(tag)], onclick: 'event.stopPropagation()' }.tag(:a, CGI.escapeHTML(tag)) }.join(' ') }
  - t.col(title: 'Data') { |o| trim(o.data.to_json) }
