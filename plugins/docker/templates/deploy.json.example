{
  "default": {
    "server": "root@srv.example.com",
    "env": {
      "RACK_ENV": "production",
      "DB_URL": "postgres:///{{app_underscored}}",
      "SECRET_KEY_BASE": true
    },
    "services": {
      "web": {
        "compose_service": "web",
        "host_port": 3100,
        "container_port": 3000,
        "domains": ["example.com", "www.example.com"],
        "healthcheck": { "path": "/", "expect_status": [200, 301, 302] }
      },
      "socket": {
        "compose_service": "socket",
        "host_port": 3101,
        "container_port": 3000,
        "domains": ["socket.example.com"],
        "healthcheck": { "path": "/health", "expect_status": [200] }
      }
    }
  },
  "staging": {
    "tls": {
      "dns_provider": "cloudflare",
      "api_token_env": "CLOUDFLARE_API_TOKEN"
    },
    "env": {
      "RACK_ENV": "staging",
      "POSTGRES_DB": "app",
      "POSTGRES_USER": "app",
      "POSTGRES_PASSWORD": "$generate",
      "DB_URL": "postgres://app:{{env.POSTGRES_PASSWORD}}@db:5432/app"
    },
    "services": {
      "web": {
        "compose_service": "web",
        "host_port": null,
        "port_range": [3500, 3899],
        "domains": ["*.staging.example.com"]
      },
      "socket": {
        "compose_service": "socket",
        "host_port": null,
        "port_range": [3900, 3999],
        "domains": ["*.sockets.staging.example.com"]
      }
    }
  },
  "pr": {
    "extends": "staging"
  }
}
