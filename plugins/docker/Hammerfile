require_relative 'lib/lux_docker'

module LuxDockerHammer
  module_function

  def profile(opts)
    opts[:profile] || (opts[:args] && opts[:args].first) || 'default'
  end

  # Everything after the profile positional is treated as passthrough,
  # used by `docker:server:compose -- <docker compose args>`.
  def passthrough(opts)
    Array(opts[:args])[1..] || []
  end

  def run(opts)
    yield
  rescue => e
    LuxDocker.handle_cli_error(e, quiet: opts[:quiet])
  end
end

namespace :docker do
  task :prepare do
    desc 'Scaffold Dockerfile + compose.yml + deploy.json (AI-assisted, reads Procfile)'
    opt :force, type: :boolean, default: false, desc: 'Overwrite existing files'
    opt :print, type: :boolean, default: false, desc: 'Print the AI prompt to stdout instead of invoking claude'
    opt :dry_run, type: :boolean, default: false, desc: 'Write the prompt file but do not invoke claude'

    proc do |opts|
      LuxDockerHammer.run(opts) { LuxDocker::Commands.prepare(nil, opts) }
    end
  end

  task :build do
    desc 'Build images locally and write tmp/deploy/<app>/images.tar.gz'
    opt :profile, desc: 'Deploy profile (positional ok)'
    opt :app, desc: 'App identifier'
    opt :config, desc: 'Path to config/deploy.json'
    opt :image_tag, desc: 'Docker image tag to apply'
    opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

    proc do |opts|
      LuxDockerHammer.run(opts) { LuxDocker::Commands.build(LuxDockerHammer.profile(opts), opts) }
    end
  end

  task :run do
    desc 'Run the full image stack locally in the foreground (Ctrl-C to stop)'
    opt :profile, desc: 'Deploy profile (positional ok)'
    opt :app, desc: 'App identifier'
    opt :config, desc: 'Path to config/deploy.json'
    opt :image_tag, desc: 'Docker image tag to apply'
    opt :build, type: :boolean, default: false, desc: 'Rebuild archive before run'
    opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

    proc do |opts|
      LuxDockerHammer.run(opts) { LuxDocker::Commands.run(LuxDockerHammer.profile(opts), opts) }
    end
  end

  namespace :server do
    task :prepare do
      desc 'Provision the remote host (apt, docker, caddy, deployer, ssh hardening, UFW)'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :with, desc: 'Comma-separated optional addons: postgres,memcache'
      opt :dry_run, type: :boolean, default: false, desc: 'Print resolved plan, do not execute'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.server_prepare(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :doctor do
      desc 'Read-only host + manifest diagnosis'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :app, desc: 'App identifier (filter manifests)'
      opt :service_user, desc: 'Service user (default deployer)'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.doctor(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :deploy do
      desc 'Deploy app to PROFILE (docker compose up, caddy reload)'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :app, desc: 'App identifier'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :image_tag, desc: 'Docker image tag to deploy'
      opt :service_user, desc: 'Service user (default deployer)'
      opt :env, desc: 'Env override KEY=VAL or KEY (comma-separated ok)'
      opt :transport, desc: 'Image transport: archive (default) or registry'
      opt :build, type: :boolean, default: false, desc: 'Build archive first if missing'
      opt :staging, type: :boolean, default: false, desc: 'Disposable staging/PR stack (requires project-local db service)'
      opt :allow_no_db, type: :boolean, default: false, desc: 'With --staging: skip project-local db service check'
      opt :dry_run, type: :boolean, default: false, desc: 'Print resolved plan, do not execute'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.deploy(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :remove do
      desc 'Tear down a deploy (compose down + caddy unlink)'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :app, desc: 'App identifier'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :volumes, type: :boolean, default: false, desc: 'Also remove named volumes (destroys staging DB)'
      opt :purge, type: :boolean, default: false, desc: 'Also remove the app directory'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.remove(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :ssh do
      desc 'Open interactive SSH in the app directory'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :app, desc: 'App identifier'
      opt :service_user, desc: 'Service user (default deployer)'
      opt :dry_run, type: :boolean, default: false, desc: 'Print commands, do not execute'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.ssh(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :logs do
      desc 'docker compose logs against the remote app'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :app, desc: 'App identifier'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :service, desc: 'Compose service to filter'
      opt :tail, desc: 'Lines of recent log output'
      opt :follow, type: :boolean, default: false, desc: 'Follow logs'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        LuxDockerHammer.run(opts) { LuxDocker::Commands.logs(LuxDockerHammer.profile(opts), opts) }
      end
    end

    task :compose do
      desc 'Run a docker compose subcommand against the remote stack (lux docker:server:compose [PROFILE] -- ps)'
      opt :profile, desc: 'Deploy profile (positional ok)'
      opt :app, desc: 'App identifier'
      opt :server, desc: 'SSH target USER@SERVER'
      opt :config, desc: 'Path to config/deploy.json'
      opt :quiet, type: :boolean, default: false, desc: 'CI-friendly output'

      proc do |opts|
        opts[:args] = Array(opts[:args])
        sep = opts[:args].index('--')
        passthrough = sep ? opts[:args][(sep + 1)..] : LuxDockerHammer.passthrough(opts)
        LuxDockerHammer.run(opts) do
          LuxDocker::Commands.compose(LuxDockerHammer.profile(opts), opts.merge(args: passthrough))
        end
      end
    end
  end
end
