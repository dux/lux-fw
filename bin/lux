#!/usr/bin/env ruby
# -*- mode: ruby -*-

if File.exist?('lux-fw.gemspec')
  puts "Can't run in lux folder"
  exit
end

require 'dotenv'
require_relative '../lib/overload/thread_simple'
require_relative '../lib/overload/string'

Dotenv.load

LUX_ROOT ||= File.expand_path '../..', __FILE__

puts 'Lux v%s (%s)' % [File.read('%s/.version' % LUX_ROOT).strip, LUX_ROOT] unless ARGV[0]

require 'lux-hammer'

# Build a single CLI that pulls in:
#   1. lux-fw's Hammerfile (core commands + plugin fragments)
#   2. *_hammer.rb fragments under the app's cwd (app commands)
Hammer.run ARGV do
  load File.join(LUX_ROOT, 'Hammerfile')
  load Dir.pwd if Dir.pwd != LUX_ROOT
end
