## Client-generation recipe (language-agnostic)

For any target language:

1. **Fetch** `<%= absolute("#{mount_on}/sys/schema") %>` at build time (or
   at startup, for dynamic clients).
2. **Emit one function per action**:
   - Collection: `client.<api>.<action>(params)` -> POST `<path>`.
   - Member: `client.<api>.<action>(id, params)` -> POST `<path with :ref
     replaced>`.
3. **Type the params** from the `params` map (`type`, `required`, `default`).
4. **Add a `login(user, pass)` method** that calls the discovered `unsafe`
   login action and stores the returned token on the client instance.
5. **Inject `Authorization: Bearer <token>`** on every non-`unsafe` call.
6. **Parse the response**: if `body.error` is set, raise; otherwise return
   `body.data ?? body`.

That gives you a usable, typed client in any language. Snippets for common
targets follow.

### Ruby (with Thor)

```ruby
require 'thor'
require 'net/http'
require 'json'

class Cli < Thor
  BASE = '<%= base_url %><%= mount_on %>'

  desc 'login USER PASS', 'log in and cache the token to ~/.api_token'
  def login(user, pass)
    res = post('/user/login', user: user, pass: pass, _no_auth: true)
    File.write(File.expand_path('~/.api_token'), res.to_s)
    say "ok"
  end

  desc 'example-create NAME', 'create an example'
  def example_create(name)
    say post('/example/create', name: name).inspect
  end

  desc 'example-update ID NAME', 'update an example by id'
  def example_update(id, name)
    say post("/example/#{id}/update", name: name).inspect
  end

  no_commands do
    def post(path, **params)
      uri = URI("#{BASE}#{path}")
      req = Net::HTTP::Post.new(uri, 'Content-Type' => 'application/json')
      unless params.delete(:_no_auth)
        req['Authorization'] = "Bearer #{File.read(File.expand_path('~/.api_token')).strip}"
      end
      req.body = params.to_json
      res = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == 'https') { |h| h.request(req) }
      body = JSON.parse(res.body) rescue res.body
      raise "API error: #{body['error']}" if body.is_a?(Hash) && body['error']
      body.is_a?(Hash) ? (body['data'] || body) : body
    end
  end
end

Cli.start(ARGV)
```

### Ruby (with `lux-hammer`)

`lux-hammer` (`gem install lux-hammer`) is a zero-dep CLI builder with a
`task :name do ... end` DSL. Same idea as the Thor example, terser:

```ruby
BASE  ||= '<%= base_url %><%= mount_on %>'
STATE ||= File.expand_path('~/.api_token')

def api_post(path, params = {}, no_auth: false)
  uri  = URI("#{BASE}#{path}")
  req  = Net::HTTP::Post.new(uri, 'Content-Type' => 'application/json')
  req['Authorization'] = "Bearer #{File.read(STATE).strip}" unless no_auth
  req.body = params.to_json
  res = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == 'https') { |h| h.request(req) }
  body = JSON.parse(res.body) rescue res.body
  raise "API error: #{body['error']}" if body.is_a?(Hash) && body['error']
  body.is_a?(Hash) ? (body['data'] || body) : body
end

task :login do
  desc 'log in and cache token'
  opt :user, req: true
  opt :pass, req: true
  proc do |o|
    File.write(STATE, api_post('/user/login', { user: o[:user], pass: o[:pass] }, no_auth: true).to_s)
    say.green 'ok'
  end
end

namespace :example do
  task :create do
    desc 'create example'
    opt :name, req: true
    proc { |o| say.green api_post('/example/create', name: o[:name]).inspect }
  end
end
```

### Java (sketch)

```java
public class Client {
    private final HttpClient http = HttpClient.newHttpClient();
    private final String base;
    private String token;

    public Client(String base) { this.base = base; }

    public void login(String user, String pass) throws Exception {
        var body = post("/user/login", Map.of("user", user, "pass", pass), false);
        this.token = body.toString();
    }

    public Object exampleCreate(String name) throws Exception {
        return post("/example/create", Map.of("name", name), true);
    }

    private Object post(String path, Map<String,Object> params, boolean auth) throws Exception {
        var b = HttpRequest.newBuilder(URI.create(base + path))
            .header("Content-Type", "application/json")
            .POST(HttpRequest.BodyPublishers.ofString(toJson(params)));
        if (auth) b.header("Authorization", "Bearer " + token);
        var res = http.send(b.build(), HttpResponse.BodyHandlers.ofString());
        return parseAndCheck(res.body());
    }
}
```

### C# (sketch)

```csharp
public class ApiClient {
    private readonly HttpClient _http = new();
    private readonly string _base;
    private string? _token;

    public ApiClient(string baseUrl) { _base = baseUrl; }

    public async Task LoginAsync(string user, string pass) {
        var data = await Post("/user/login", new { user, pass }, auth: false);
        _token = data?.ToString();
    }

    public Task<object?> ExampleCreate(string name) =>
        Post("/example/create", new { name }, auth: true);

    private async Task<object?> Post(string path, object body, bool auth) {
        var req = new HttpRequestMessage(HttpMethod.Post, _base + path) {
            Content = JsonContent.Create(body)
        };
        if (auth) req.Headers.Authorization = new("Bearer", _token);
        var res = await _http.SendAsync(req);
        var json = await res.Content.ReadFromJsonAsync<JsonElement>();
        if (json.TryGetProperty("error", out var err)) throw new Exception(err.GetString());
        return json.TryGetProperty("data", out var d) ? d : json;
    }
}
```

The pattern is identical in every language: `Authorization: Bearer <token>`,
POST a JSON body, check for `error`, return `data` if present.
